# ===========================
# WiseMove Connect - Environment Variables
# Copy this file to .env and fill in your values
# ===========================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/wisemove

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Admin Seed Credentials (used by seed script only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Email (Resend)
RESEND_API_KEY=re_123456789
EMAIL_FROM=noreply@wisemoveconnect.com

# SendPulse (SMS + WhatsApp)
SENDPULSE_CLIENT_ID=your_client_id
SENDPULSE_CLIENT_SECRET=your_client_secret
SENDPULSE_SMS_SENDER=WiseMove
SENDPULSE_WHATSAPP_BOT_ID=your_bot_id

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin notification email (receives alerts for unassigned leads)
ADMIN_EMAIL=admin@wisemoveconnect.com

# CORS — comma-separated list of allowed origins (e.g. http://localhost:3000,http://localhost:3001)
# Use * to allow all origins (default)
ALLOWED_ORIGINS=*

# Stripe
STRIPE_SECRET_KEY=sk_test_12345
STRIPE_WEBHOOK_SECRET=whsec_12345
STRIPE_SUCCESS_URL=http://localhost:3000/payment-success
STRIPE_CURRENCY=gbp
