# ===========================
# WiseMove Connect - Environment Variables
# Copy this file to .env and fill in your values
# ===========================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/wisemove

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Admin Seed Credentials (used by seed script only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Email (SMTP - e.g. SendGrid, Gmail)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@wisemoveconnect.com

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+441234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin notification email (receives alerts for unassigned leads)
ADMIN_EMAIL=admin@wisemoveconnect.com

# CORS — comma-separated list of allowed origins (e.g. http://localhost:3000,http://localhost:3001)
# Use * to allow all origins (default)
ALLOWED_ORIGINS=*
